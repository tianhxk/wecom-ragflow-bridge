# ============================================
# 企业微信智能机器人 <-> RAGFLOW 桥接服务 配置
# ============================================
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# ---------- 企业微信配置 ----------
# 在企业微信管理后台 -> 应用管理 -> 智能机器人 -> 开启API模式 -> 选择"长连接"
# 获取 BotID 和 Secret
WECOM_BOT_ID=你的BotID
WECOM_SECRET=你的Secret

# 企业 ID（用于图片识别等 API 调用）
# 在企业微信管理后台 -> 我的企业 -> 企业信息 -> 企业 ID
WECOM_CORP_ID=你的CorpID

# ---------- RAGFLOW 配置 ----------
# RAGFLOW API 地址（因为桥接服务和 RAGFLOW 在同一 Docker 网络，可用内部地址,只需要写域名）
RAGFLOW_API_BASE=http://nginx/

# RAGFLOW 应用的 API Key（在 RAGFLOW 控制台 -> 你的应用 -> API 访问 中获取）
RAGFLOW_API_KEY=你的APIKey

# RAGFLOW 应用的 API Key（在 RAGFLOW 控制台 -> agent应用 -> 具体的智能体-右上角-管理-嵌入网站中获得 访问 中获取）
RAGFLOW_AGENT_ID=你的AgentID

# ---------- 可选配置 ----------
# 是否启用流式回复（推荐开启，打字机效果）
STREAM_MODE=true

# 心跳间隔（秒）
HEARTBEAT_INTERVAL=30

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
